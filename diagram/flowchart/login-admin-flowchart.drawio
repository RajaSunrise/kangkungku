<mxfile host="app.diagrams.net" modified="2026-04-27T00:00:00.000Z" agent="5.0" version="22.1.0" type="device">
  <diagram name="Login Admin Flowchart" id="login-admin-flow">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="FLOWCHART LOGIN ADMIN" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1D3557;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="[MULAI]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2A9D8F;fontColor=#FFFFFF;fontStyle=1;fontSize=12;strokeColor=#264653;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Form Login Admin -->
        <mxCell id="form_login" value="Form Login Admin&#xa;(Username &amp; Password)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#A8DADC;fontSize=11;strokeColor=#1D3557;" vertex="1" parent="1">
          <mxGeometry x="500" y="160" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Validasi Login Decision -->
        <mxCell id="validasi_login" value="Validasi Login&#xa;(Cek Username &amp; Password)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E9C46A;fontSize=11;strokeColor=#264653;" vertex="1" parent="1">
          <mxGeometry x="510" y="240" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Login Failed -->
        <mxCell id="login_gagal" value="Login Gagal&#xa;(Tampilkan Error)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E76F51;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="260" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Back to Form Login -->
        <mxCell id="back_login" value="Kembali ke&#xa;Form Login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4A261;fontColor=#FFFFFF;fontSize=10;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Login Success -->
        <mxCell id="login_berhasil" value="Login Berhasil&#xa;(Akses Menu Admin)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2A9D8F;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="260" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Menu Admin Dashboard -->
        <mxCell id="menu_admin" value="Menu Admin Dashboard" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#457B9D;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="340" width="180" height="45" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="[SELESAI]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E76F51;fontColor=#FFFFFF;fontStyle=1;fontSize=12;strokeColor=#264653;" vertex="1" parent="1">
          <mxGeometry x="540" y="560" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow: Start to Form Login -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="start" target="form_login">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Form Login to Validasi -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="form_login" target="validasi_login">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Validasi to Login Gagal (Salah) -->
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="validasi_login" target="login_gagal">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="480" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Validasi to Login Berhasil (Benar) -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="validasi_login" target="login_berhasil">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Login Gagal to Back Login -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="login_gagal" target="back_login">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Back Login to Form Login -->
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="back_login" target="form_login">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="365" />
              <mxPoint x="200" y="185" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Login Berhasil to Menu Admin -->
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="login_berhasil" target="menu_admin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Menu Admin to End -->
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#264653;strokeWidth=2;" edge="1" parent="1" source="menu_admin" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="180" height="160" as="geometry" />
        </mxCell>

        <mxCell id="legend_title" value="LEGENDA" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#1D3557;" vertex="1" parent="1">
          <mxGeometry x="70" y="85" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg_start" value="[MULAI/SELESAI]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2A9D8F;fontColor=#FFFFFF;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="115" width="80" height="25" as="geometry" />
        </mxCell>

        <mxCell id="leg_process" value="Proses" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#457B9D;fontColor=#FFFFFF;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="80" height="25" as="geometry" />
        </mxCell>

        <mxCell id="leg_form" value="Form/Input" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#A8DADC;fontSize=9;strokeColor=#1D3557;" vertex="1" parent="1">
          <mxGeometry x="30" y="185" width="80" height="25" as="geometry" />
        </mxCell>

        <mxCell id="leg_decision" value="Keputusan" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E9C46A;fontSize=9;strokeColor=#264653;" vertex="1" parent="1">
          <mxGeometry x="30" y="220" width="80" height="35" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
