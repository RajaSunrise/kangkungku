        <mxCell id="res_disease" value="Karat Putih (White Rust)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#2BEE4B;fontSize=36;fontStyle=1;fontFamily=Space Grotesk;" vertex="1" parent="1">
