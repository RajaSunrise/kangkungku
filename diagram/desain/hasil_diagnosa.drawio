        <mxCell id="circle_lbl" value="Tingkat Kepastian" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#6B7280;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="525" y="580" width="150" height="30" as="geometry" />
        </mxCell>

        <!-- Deskripsi Section -->
        <mxCell id="desc_title" value="Deskripsi Penyakit" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#111812;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="660" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="desc_txt" value="Karat Putih adalah penyakit yang disebabkan oleh oomycete Albugo ipomoeae-panduratae. Penyakit ini sangat umum terjadi pada tanaman kangkung, terutama di lingkungan dengan kelembaban tinggi dan sirkulasi udara yang buruk. Gejala awal dimulai dengan bintik kuning kecil di permukaan atas daun, yang kemudian diikuti oleh munculnya pustula putih berkapur di bagian bawah daun." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="260" y="700" width="680" height="100" as="geometry" />
        </mxCell>

        <!-- Solusi Section -->
        <mxCell id="sol_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#10B981;" vertex="1" parent="1">
          <mxGeometry x="260" y="820" width="680" height="240" as="geometry" />
        </mxCell>
        <mxCell id="sol_title" value="💡 Solusi &amp; Penanganan" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#065F46;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="840" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sol_txt" value="[TINDAKAN SEGERA] Segera cabut dan musnahkan daun atau bagian tanaman yang memiliki pustula putih.&#xa;&#xa;[PENGOBATAN] Gunakan fungisida organik berbasis sulfur atau semprotan air rebusan daun sirih. Jika parah, gunakan fungisida berbahan aktif tembaga oksida.&#xa;&#xa;[PENCEGAHAN] Atur jarak tanam 15-20 cm untuk sirkulasi udara. Hindari penyiraman langsung pada daun di sore hari." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#064E3B;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="290" y="890" width="620" height="150" as="geometry" />
        </mxCell>

        <!-- Detail Gejala Section -->
        <mxCell id="det_title" value="Detail Gejala yang Dipilih" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#111812;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="1100" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="det_list" value="• G001 - Bercak putih menonjol pada sisi bawah daun (Keyakinan User: 0.8)&#xa;• G003 - Daun melengkung atau terdistorsi (Keyakinan User: 0.4)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="260" y="1140" width="680" height="80" as="geometry" />
        </mxCell>

